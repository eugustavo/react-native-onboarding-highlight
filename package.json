{
  "name": "react-native-onboarding-highlight",
  "version": "0.2.0",
  "description": "React Native onboarding library with spotlight highlighting and animated tooltips",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src/",
    "lib/",
    "!src/example.tsx",
    "!**/*.map"
  ],
  "scripts": {
    "prepare": "bob build && npm run clean:sourcemaps && npm run clean:examples",
    "build": "bob build && npm run clean:sourcemaps && npm run clean:examples",
    "clean:sourcemaps": "find lib -name '*.map' -type f -delete",
    "clean:examples": "rm -f lib/commonjs/example.js lib/module/example.js lib/typescript/example.d.ts lib/typescript/example.d.ts.map",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf lib"
  },
  "keywords": [
    "react-native",
    "onboarding",
    "tutorial",
    "spotlight",
    "highlight",
    "tooltip",
    "walkthrough"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eugustavo/react-native-onboarding-highlight.git"
  },
  "homepage": "https://github.com/eugustavo/react-native-onboarding-highlight#readme",
  "bugs": {
    "url": "https://github.com/eugustavo/react-native-onboarding-highlight/issues"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": ">=3.0.0",
    "react-native-svg": ">=13.0.0"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.75.0",
    "@testing-library/react-native": "^12.5.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-builder-bob": "^0.23.0",
    "react-native-reanimated": "~3.6.0",
    "react-native-safe-area-context": "^4.9.0",
    "react-native-svg": "^14.1.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.3.0"
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ]
}
